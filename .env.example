# Chaves da MasterPag (peça em Configurações -> Chaves API).
# Use pk_test_/sk_test_ para testes e pk_live_/sk_live_ em produção.
# NUNCA comite as chaves reais. Configure-as em Vercel -> Settings -> Environment Variables.

MASTERPAG_BASE_URL=https://api.masterpag.com/functions/v1
MASTERPAG_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
MASTERPAG_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# Secret usado para validar a assinatura dos webhooks (opcional, mas recomendado).
MASTERPAG_WEBHOOK_SECRET=

# URL pública do seu webhook depois do deploy (ex.: https://www.delivery-pedidosdebebidas.shop/api/webhook).
WEBHOOK_URL=

# ===== Painel de pedidos (/administracao-dosclientes) =====
# Senha de acesso ao painel (escolha uma forte). O painel envia no header Authorization.
ADMIN_TOKEN=

# Armazenamento dos pedidos. Crie um Vercel KV (Storage -> KV) e ele injeta estas vars,
# ou use Upstash Redis direto (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN).
KV_REST_API_URL=
KV_REST_API_TOKEN=
