<header class="header js-header" role="banner" itemscope itemtype="http://schema.org/WPHeader">
    <div class="header__container">
        
        <a class="header__logo-link" href="/" title="The Whisky Exchange - World of Fine Spirits">
            <picture>
                <source srcset="/media/rtwe/assets/application-v2/images/logos/twe-logo-word.svg" width="200" height="56" media="(max-width: 449.9px)" alt="The Whisky Exchange - World of Fine Spirits" />
                <source srcset="/media/rtwe/assets/application-v2/images/logos/twe-logo-word.svg" width="200" height="56" media="(min-width: 450px)" alt="The Whisky Exchange - World of Fine Spirits" />
                <img src="/media/rtwe/assets/application-v2/images/logos/twe-logo-word.svg" width="200" height="56" alt="The Whisky Exchange - World of Fine Spirits">
            </picture>
        </a>
        

        <div id="twesearch" class="header__search">
            

            
                <form class="header-search header-search--v2 js-header-search" id="formSearchInput">
                    <input type="text" placeholder="Search for your perfect bottle" class="header-search__input" id="txtSearchInput">
                    <button type="submit" class="header-search__button" id="btnSearchInput" name="Search" aria-label="Search">
                        <img class="header-search__image" src="/media/rtwe/assets/application-v2/images/homepage/icon_search.svg?v=25092025" alt="search icon">
                    </button>
                </form>
            
        </div>

        <a class="header-button header-button--account" href="/account/home" title="Account" onclick="_gaq.push(['trackBrandNavIconClick','Account-Icon'])">
            <div class="header-button__icon">
                <img class="header-button__image" src="/media/rtwe/assets/application-v2/images/icons/rebrand-icon_account.svg" alt="Account"/>
            </div>
        </a>

        <details class="header-item header-item__subnav header-item__subnav--basket js--dropdown" data-pop="tweBasket">
            <summary class="header-button header-button--basket js--header-links__link">
                <div class="header-button__icon">
                    <img class="header-button__image" src="/media/rtwe/assets/application-v2/images/icons/rebrand-icon_basket.svg" alt="Basket"/>
                </div>
                <div class="header-link__label js--labelbasket"></div>
            </summary>
            <div class="header-pop__container header-pop__container--basket js--basketsummary">
                <div id="tweBasketSummary" class="headersummary">
                    Your basket is currently empty.
                </div>
